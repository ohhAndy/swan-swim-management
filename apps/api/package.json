{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json --forceExit",
    "db:test:start": "docker compose -f ../../docker-compose.test.yml up -d",
    "db:test:push": "cd ../../packages/db && dotenv -e ../../apps/api/.env.test -- npx prisma db push --accept-data-loss"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.8.0",
    "compression": "^1.8.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "nestjs-zod": "^5.0.1",
    "pg": "^8.16.3",
    "resend": "^6.9.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.13",
    "@types/compression": "^1.8.1",
    "@types/exceljs": "^0.5.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.39.2",
    "globals": "^14.0.0",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.1",
    "prisma": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript-eslint": "^8.62.1"
  }
}
